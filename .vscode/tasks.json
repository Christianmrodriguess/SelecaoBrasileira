{
  "version": "2.0.0",
  "tasks": [
    {
        "label": "Compilar C",
        "type": "shell",
        "command": "C:\\MinGW\\bin\\gcc.exe",
        "args": [
            "-g",
            "${file}",
            "-o",
            "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
        ],
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "problemMatcher": [
            "$gcc"
        ]
    }
]
}